{
  // appsettings.json — Uygulamanın TÜM ortamlarda geçerli temel yapılandırması.
  // Bu dosya Git'e COMMIT EDİLİR; bu yüzden içine GİZLİ değer (gerçek şifre,
  // gerçek bağlantı dizesi, JWT secret) YAZILMAZ. Gizli değerler ortama özel
  // `appsettings.Development.json` (geliştirme) veya sunucu ortam değişkenlerine
  // (production) konur ve bu temel ayarların üzerine yazar. (bkz. ENV.md)

  // Loglama seviyeleri — hangi kaynaktan hangi önem derecesinden itibaren log yazılır.
  "Logging": {
    "LogLevel": {
      // Varsayılan: Information ve üzeri (Info/Warning/Error/Fatal) loglanır.
      "Default": "Information",
      // ASP.NET Core altyapı logları gürültülü; yalnızca Warning ve üzerini göster.
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Hangi Host başlıklarının (Host header) kabul edileceği. "*" = hepsi.
  // NEDEN: Host header doğrulaması; production'da gerçek domain'le sınırlanabilir.
  "AllowedHosts": "*",

  // Veritabanı bağlantı dizeleri. Burada BOŞ — gerçek değer gizlidir ve
  // `appsettings.Development.json` / ortam değişkeni ile gelir (ENV.md §1).
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  // JWT (JSON Web Token) ayarları — kullanıcı giriş token'larının üretiminde kullanılır.
  // SecretKey BURADA YOK (gizli); yalnızca gizli olmayan alanlar burada.
  "Jwt": {
    // Token'ı kimin ürettiği (issuer) — doğrulamada kontrol edilir.
    "Issuer": "WordLearnerApp",
    // Token'ın kimin için geçerli olduğu (audience) — doğrulamada kontrol edilir.
    "Audience": "WordLearnerApp",
    // Access token ömrü (dakika). Kısa tutulur; yenileme refresh token ile yapılır.
    "ExpirationMinutes": 15,
    // Refresh token ömrü (gün). Access token'dan çok daha uzun.
    "RefreshTokenExpirationDays": 7
  },

  // CORS — tarayıcıdan API'a hangi kaynakların (origin) istek atabileceği.
  // NEDEN: Güvenlik için "*" değil, yalnızca bilinen frontend adresleri.
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8081", // Expo (mobil geliştirme)
      "http://localhost:5173", // Admin panel (Vite)
      "http://localhost:5174"  // Web app (Vite)
    ]
  }
}
